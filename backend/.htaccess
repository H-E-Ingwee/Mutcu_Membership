<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /mutcu_membership/backend/

    # Allow setup.php and other direct PHP files to be accessed
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Only rewrite /api/ requests to index.php
    RewriteCond %{REQUEST_URI} ^/mutcu_membership/backend/api/
    RewriteRule ^api/(.*)$ index.php?request=api/$1 [QSA,L]
</IfModule>

# Protect sensitive directories
<Directory "/mutcu_membership/backend/config">
    Deny from all
</Directory>

<Directory "/mutcu_membership/backend/database">
    Deny from all
</Directory>

<Directory "/mutcu_membership/backend/utils">
    Deny from all
</Directory>

<Directory "/mutcu_membership/backend/middleware">
    Deny from all
</Directory>
