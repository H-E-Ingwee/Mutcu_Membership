<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /mutcu_membership/backend/

    # Allow setup.php and other direct PHP files to be accessed
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Only rewrite /api/ requests to index.php
    RewriteCond %{REQUEST_URI} ^/mutcu_membership/backend/api/
    RewriteRule ^api/(.*)$ index.php?request=api/$1 [QSA,L]
</IfModule>

# Protect sensitive files and directories from direct access
# Block access to config directory files
<FilesMatch "(config|database|utils|middleware)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent direct access to sensitive PHP files
<FilesMatch "(Config|Database|Auth|Response|Validator|CheckAuth|CORS)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
