<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /mutcu_membership/
    
    # Allow existing files and directories to be accessed directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Allow all .php files to be accessed directly (for pages folder, etc)
    RewriteCond %{REQUEST_URI} !\.php$
    
    # Only rewrite requests that start with /api/ to backend
    RewriteCond %{REQUEST_URI} ^/mutcu_membership/api/
    RewriteRule ^api/(.*)$ backend/index.php?request=api/$1 [QSA,L]
</IfModule>
